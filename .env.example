# Copia este archivo a .env y rellena los valores reales. NO comitees .env.
# Sin credenciales, cada conector arranca en modo demo (datos de ejemplo).

PORT=3001

# --- LLM (OpenAI) ---
# Con la key, el agente interpreta cualquier pregunta vía tool-calling.
# Sin ella, cae automáticamente al motor por palabras clave (sin coste).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Tenant SMTP2 (ERP real: GlobalApi, SQL sobre HTTP con cabecera X-Api-Key) ---
# Sin la key → el conector arranca en modo demo con datos de ejemplo.
SMTP2_ERP_API_KEY=

# --- Tenant Demo (Shopify) ---
DEMO_SHOPIFY_DOMAIN=demo-shop.myshopify.com
DEMO_SHOPIFY_TOKEN=

# --- Shopify NACIONAL (The Extreme Collection, España + Portugal) ---
SHOPIFY_NACIONAL_DOMAIN=
SHOPIFY_NACIONAL_TOKEN=
# (compat) token suelto anterior
SHOPIFY_ACCESS_TOKEN=

# --- Shopify INTERNACIONAL (pendiente de credenciales) ---
# SHOPIFY_INTER_DOMAIN=
# SHOPIFY_INTER_TOKEN=

# --- Tenant ACME (SQL / PostgreSQL) ---
# Con connectionString real (y `npm install pg`) el conector introspecciona el esquema.
# Vacío → modo demo con tablas de ejemplo.
ACME_DB_URL=

# Directorio del store de tenants (opcional; por defecto server/data/tenants).
# AGENTEDATOS_DATA_DIR=
