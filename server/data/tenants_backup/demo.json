      }
    }
  ],
  "mappings": [
    { "source": "orders", "target": "orders" },
    { "source": "inventory", "target": "inventory" },
    { "source": "products", "target": "products" },
    { "source": "customers", "target": "customers" }
  ],
  "tools": [
    { "name": "query_data" },
    { "name": "get_metrics" }
  ],
  "prompt": "Responde como un agente de negocio para retail."
}
