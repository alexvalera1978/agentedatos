{
  "tenant": {
    "id": "demo",
    "name": "Demo Tenant",
    "business": "retail",
    "language": "es",
    "currency": "EUR"
  },
  "sources": [
    {
      "id": "shopify-demo",
      "kind": "shopify",
      "name": "Shopify Demo",
      "config": {
        "domain": "demo-shop.myshopify.com",
        "apiKey": "${DEMO_SHOPIFY_TOKEN}",
